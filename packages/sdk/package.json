{
  "name": "@maw-js/sdk",
  "version": "1.0.0-alpha.1",
  "description": "maw-js plugin SDK — stable typed API for plugin authors.",
  "license": "BUSL-1.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Soul-Brews-Studio/maw-js.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Soul-Brews-Studio/maw-js/tree/main/packages/sdk#readme",
  "bugs": "https://github.com/Soul-Brews-Studio/maw-js/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "./index.ts",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.ts"
    },
    "./plugin": {
      "types": "./plugin.d.ts",
      "default": "./plugin.ts"
    }
  },
  "scripts": {
    "prepublishOnly": "bun test packages/sdk/"
  },
  "files": [
    "index.ts",
    "index.d.ts",
    "plugin.ts",
    "plugin.d.ts",
    "README.md",
    "LICENSE"
