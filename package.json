  "type": "module",
  "bin": {
    "maw": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outfile dist/maw --target=bun --minify",
    "deploy": "bun run build && bun src/cli.ts fleet sync && pm2 restart maw",
    "dev": "pm2 start ecosystem.config.cjs"
  },
  "description": "maw.js \u2014 Multi-Agent Workflow in Bun/TS. Remote tmux orchestra control. CLI + Web UI.",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "grammy": "^1.42.0",
    "hono": "^4.12.5",
    "mqtt": "^5.15.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.2",
    "zustand": "^5.0.11",
    "aedes": "^1.0.2",
    "drizzle-orm": "^0.45.2",
    "puppeteer-core": "^24.40.0",
    "zod": "^4.3.6",
    "discord.js": "^14.26.2"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.0",
